# Backend Environment Variables Template
# Copy this to .env and fill in your values

PORT=4000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenRouter (AI auto-tagging via vision model) ─────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_FALLBACK_MODEL=google/gemma-3-12b-it:free
OPENROUTER_SECONDARY_FALLBACK_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_FOURTH_FALLBACK_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
OPENROUTER_FIFTH_FALLBACK_MODEL=google/gemma-3-4b-it:free

# ── Deployment URLs ─────────────────────────────────────────────────────────
# Set these to your production URLs for CORS + cross-service communication
# Production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Production: https://your-ml-service.onrender.com (or local)
ML_SERVICE_URL=http://localhost:8000

# ── Legacy admin key (used on non-Supabase routes during migration) ───────────
# Consider removing this post-migration and using Supabase auth exclusively
API_SECRET_KEY=sb_secret_...
